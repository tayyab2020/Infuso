DATABASE_URL="postgresql://user:password@127.0.0.1:5432/infuso_store?schema=public"
SESSION_SECRET="change-this-to-a-long-random-string-in-production"
PORT=3000

# Used only by prisma/seed.js to create the first admin login
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# Order confirmation emails (nodemailer SMTP transport). Leave SMTP_HOST blank
# to just log emails to the console instead of sending them.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="INFUSO <sales@infuso.pk>"

# Where new-order notifications are sent (in addition to the customer's own
# confirmation email). Takes priority over Settings' public contactEmail field.
# Must NOT be the same address as MAIL_FROM/contactEmail if that address is a
# Gmail "Send mail as" alias — Gmail silently drops self-addressed mail sent
# from a verified alias to itself (delivered to Sent only, never Inbox).
ADMIN_NOTIFY_EMAIL=sales@infuso.pk

# Meta Pixel + Conversions API. Pixel ID is not secret (it's already embedded
# in the storefront's client-side code); the access token IS secret and must
# never be exposed to the browser — generate it in Events Manager > Data
# Sources > your pixel > Settings > Conversions API > "Generate access token".
# Leave META_CAPI_ACCESS_TOKEN blank to disable server-side event sending
# (client-side Pixel tracking still works on its own).
META_PIXEL_ID=1703900774196311
META_CAPI_ACCESS_TOKEN=
# Paste the code shown in Events Manager > Test Events while testing, then
# clear it again before going live — events sent with a test code are excluded
# from real reporting.
META_TEST_EVENT_CODE=
